# Auto-detect text files and normalise line endings to LF in the repo.
# Git will convert to CRLF on Windows checkout automatically.
* text=auto

# Explicitly LF for Python and config files
*.py    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.csv   text eol=lf

# Binary files — no line ending conversion
*.xlsx  binary
*.png   binary
*.jpg   binary
