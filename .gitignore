# ── Credentials — NEVER commit these ──────────────────────────────
config.json

# ── Runtime data — generated by the bot, stays local ──────────────
data/
Study/
Dependencies/all_instrument*

# ── Generated reports ─────────────────────────────────────────────
*.html
reports/

# ── Logs ──────────────────────────────────────────────────────────
logs/
*.log

# ── Excel tracker (runtime file, not source) ───────────────────────
*.xlsx
*.xlsm

# ── Local dependencies folder ─────────────────────────────────────
# Ignore the entire Dependencies folder and its contents
Dependencies/

# Catch any "glitched" Windows-style filenames with backslashes
Dependencies\*
"Dependencies\\*"

# ── Python ────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ───────────────────────────────────────────
venv/
.venv/
env/
.env/

# ── IDE / OS ───────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

